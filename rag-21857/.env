# Choose Model Backend: 0 -> ML Dev, 1 -> Vertex
GOOGLE_GENAI_USE_VERTEXAI=1

# Vertex backend config
# Aligning to Frankfurt where we successfully built the RAG index
GOOGLE_CLOUD_PROJECT=ai-trading-assistant-488403
GOOGLE_CLOUD_LOCATION=europe-west3
GOOGLE_CLOUD_REGION=europe-west3

# Existing corpus in Vertex RAG Engine (Frankfurt ID)
RAG_CORPUS=projects/521864748129/locations/europe-west3/ragCorpora/2305843009213693952

# Staging bucket name for deployment (Frankfurt bucket)
STAGING_BUCKET=gs://tbd-docs-frankfurt-ai-trading-assistant-488403

# Agent Engine ID (Leave blank; 'make deploy' will populate this in metadata)
AGENT_ENGINE_ID=

# Arize Keys for Tracing (Leave empty as you don't have an account)
# This prevents the agent from attempting to send telemetry to Arize
ARIZE_SPACE_ID=not_used
ARIZE_API_KEY=not_used
# Enable full instrumentation for the Observability Dashboard
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# Capture the actual prompt/response text in logs (crucial for debugging RAG)
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true