I0301 05:43:56.759309    5319 client.go:683] CompleteCode request: {"enablePromptEnhancement":true,"ideContext":{"currentFile":{"codeLanguage":"python","filePath":"/home/stevewwhite/rag-21857/direct_audit.py","includedReason":"CURRENTLY_OPEN","lastEdit":["DELETE","UNKNOWN_EDIT","DELETE","UNKNOWN_EDIT"],"segments":[{"content":"import vertexai\nfrom vertexai.preview import rag\nfrom vertexai.generative_models import GenerativeModel, Tool\n\n# 1. Initialize Frankfurt context explicitly\n# This ensures your $1,543.96 credit is used correctly in the right region\nvertexai.init(project=\"ai-trading-assistant-488403\", location=\"europe-west3\")\n\n# 2. Define the RAG Tool (2026 Flattened Syntax)\n# We use rag.RagResource directly, bypassing the nested VertexRagStore attribute\nrag_tool = Tool.from_retrieval(\n    retrieval=rag.Retrieval(\n        source=rag.VertexRagStore(\n            rag_resources=[\n                rag.RagResource(\n                    rag_corpus=\"projects/ai-trading-assistant-488403/locations/europe-west3/ragCorpora/2305843009213693952\"\n                )\n            ],\n            similarity_top_k=2, # Keeps the payload valid for the Frankfurt API\n        ),\n    )\n)\n\n# 3. Query the Model (Pro 002 for maximum reasoning depth on your PDFs)\nmodel = GenerativeModel(\"gemini-1.5-pro-002\")\n\nprint(\"\\n--- 🧠 Querying TBD Manuals for NYC Reversal (Direct Path) ---\")\n\n# Define the Audit Query\n# We specifically ask for the Asia High/Low rules from FL-006\nquery = \"Based on 'FL-006_ NYC Reversal Day Trade.pdf', what are the mandatory Asia High/Low rules for entry? Please identify the 'Liquidity Grab' requirements.\"\n\ntry:\n    response = model.generate_content(\n        query,\n        tools=[rag_tool]\n    )\n    \n    if response.candidates:\n        print(f\"\\nResponse:\\n{response.text}\")\n        \n        # Optional: Print citations if the model provides them\n        if hasattr(response, 'grounding_metadata') and response.grounding_metadata.search_entry_point:\n             print(f\"\\n📚 Sources verified in Frankfurt Corpus.\")\n    else:\n        print(\"\\n⚠️ No response generated. Check model access to the RAG Corpus.\")\n\nexcept Exception as e:\n    print(f\"\\n❌ Direct Audit Failed: {e}\")\n    print(\"\\nTroubleshooting Tip: If this fails with a 400, your Frankfurt RAG Index may still be syncing.\")\n\nprint(\"\\"},{"isSelected":true},{}]},"otherFiles":[{"codeLanguage":"python","filePath":"rag-21857/agent.py","includedReason":"RECENTLY_OPENED","segments":[{"content":"import os\nimport vertexai\nfrom google.adk.agents.llm_agent import LlmAgent\nfrom google.adk.tools.retrieval.vertex_ai_rag_retrieval import VertexAiRagRetrieval\nfrom vertexai.preview import rag\n\n# Initialize with explicit project/location to stabilize the async stream\nvertexai.init(project=\"ai-trading-assistant-488403\", location=\"europe-west3\")\n\n# 1. Define the RAG Tool with a stricter 'Top K' \n# This prevents the 'Request contains an invalid argument' by slimming the payload\ntbd_manuals_tool = VertexAiRagRetrieval(\n    name=\"query_tbd_manuals\",\n    description=\"Search Steve's TBD manuals for NYC Reversal rules and Fibonacci levels.\",\n    rag_resources=[\n        rag.RagResource(\n            rag_corpus=\"projects/ai-trading-assistant-488403/locations/europe-west3/ragCorpora/2305843009213693952\"\n        )\n    ],\n    similarity_top_k=2, # Critical: Higher than 2 often triggers the 400 error in streaming\n)\n\n# 2. Define the Agent with the exact stable model and detailed TBD instructions\napp = LlmAgent(\n    name=\"tbd-trading-assistant\",\n    # Pinning to the exact stable version for regional reliability in Frankfurt\n    model=\"gemini-1.5-pro-002\", \n    tools=[tbd_manuals_tool],\n    instruction=\"\"\"You are Steve's expert TBD trading assistant. Use the 'query_tbd_manuals' tool for every audit.\n    When asked for an audit, use the tool to find exact rules from the manuals. \n    Focus specifically on:\n    - NYC Reversal (FL-006)\n    - Three-Level Expansion (FL-005)\n    - Fibonacci Rejection Zones\n    If the tool returns no data, tell Steve to check if the specific manual is indexed.\"\"\"\n)"}]}]},"metadata":{"duetProject":"cloudshell-gca","ideName":"Code OSS for Cloud Shell","ideType":"CLOUD_SHELL","ideVersion":"1.104.3-cde","platform":"LINUX_AMD64","pluginType":"CLOUD_CODE","pluginVersion":"2.72.0"},"project":"cloudshell-gca","requestId":"cloudcode-871671220-18169af5-8f0b-499c-bb6e-46571f231aa6","userContext":{}}
