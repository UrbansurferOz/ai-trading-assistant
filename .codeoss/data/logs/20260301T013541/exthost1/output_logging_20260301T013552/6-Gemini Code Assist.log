I0301 04:49:39.344626    2002 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didSave: {"textDocument":{"uri":"file:///home/stevewwhite/rag-21857/agent.py"},"text":"import os\nfrom google.adk.agents.llm_agent import LlmAgent\nfrom google.adk.tools.retrieval.vertex_ai_rag_retrieval import VertexAiRagRetrieval\nfrom vertexai.preview import rag\n\n# 1. Define the RAG Tool for your TBD Manuals\n# We use VertexAiRagRetrieval because it's more stable for ADK deployments in 2026.\ntbd_manuals_tool = VertexAiRagRetrieval(\n    name=\"query_tbd_manuals\",\n    description=\"Search Steve's Trade by Design (TBD) manuals for rules, NYC Reversal setups, and Fibonacci rejection zones.\",\n    rag_resources=[\n        rag.RagResource(\n            rag_corpus=\"projects/ai-trading-assistant-488403/locations/europe-west3/ragCorpora/2305843009213693952\"\n        )\n    ],\n    similarity_top_k=2,  # Fixed at 2 to prevent the 'Invalid Argument' 400 error\n)\n\n# 2. Define the Agent and its Instruction Set\napp = LlmAgent(\n    name=\"tbd-trading-assistant\",\n    model=\"gemini-2.5-flash\", \n    tools=[tbd_manuals_tool],\n    instruction=\"\"\"You are Steve's expert Trade by Design (TBD) assistant. \n    Your primary goal is to provide precise trading audits based ONLY on the manuals found in the 'query_tbd_manuals' tool.\n    \n    When Steve asks for an audit:\n    - Reference specific files (e.g., 'FL-006 NYC Reversal').\n    - Check the mandatory Asia High/Low rule for reversals.\n    - Identify the Fibonacci 'Rejection Zone' levels.\n    - If the data isn't in the manuals, state that clearly.\"\"\"\n)"}
