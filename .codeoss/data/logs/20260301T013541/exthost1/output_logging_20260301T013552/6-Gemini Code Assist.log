I0301 06:15:23.417893    5319 client.go:683] CompleteCode request: {"enablePromptEnhancement":true,"ideContext":{"currentFile":{"codeLanguage":"python","filePath":"/home/stevewwhite/rag-21857/system_check.py","includedReason":"CURRENTLY_OPEN","lastEdit":["UNKNOWN_EDIT"],"segments":[{"content":"import vertexai\nfrom vertexai.generative_models import GenerativeModel\n\nPROJECT_ID = \"ai-trading-assistant-488403\"\n\nprint(\"\\n--- 🔍 Running Bare-Metal AI Diagnostics ---\")\n\n# Test 1: Frankfurt (europe-west3)\ntry:\n    vertexai.init(project=PROJECT_ID, location=\"europe-west3\")\n    # Using the most basic base model name\n    model = GenerativeModel(\"gemini-1.5-flash\")\n    print(\"Testing Frankfurt (europe-west3) connection...\")\n    res = model.generate_content(\"Reply with 'Frankfurt is online'.\")\n    print(f\"✅ Success: {res.text.strip()}\")\nexcept Exception as e:\n    print(f\"❌ Frankfurt Failed: {e}\")\n\n# Test 2: US Central (us-central1)\ntry:\n    vertexai.init(project=PROJECT_ID, location=\"us-central1\")\n    model = GenerativeModel(\"gemini-1.5-flash\")\n    print(\"\\nTesting US Central (us-central1) connection...\")\n    res = model.generate_content(\"Reply with 'US Central is online'.\")\n    print(f\"✅ Success: {res.text.strip()}\")\nexcept Exception as e:\n    print(f\"❌ US Central Failed: {e}\")"},{"isSelected":true},{}]},"otherFiles":[{"codeLanguage":"python","filePath":"rag-21857/direct_audit.py","includedReason":"RECENTLY_EDITED","segments":[{"content":"import vertexai\nfrom vertexai.preview import rag\nfrom vertexai.generative_models import GenerativeModel, Tool\n\n# 1. Initialize Frankfurt context\n# We use the 'europe-west3' location but the 'global' endpoint is used under the hood in 2026\nvertexai.init(project=\"ai-trading-assistant-488403\", location=\"europe-west3\")\n\n# 2. Define the RAG Tool (March 2026 Flat Syntax)\nrag_tool = Tool.from_retrieval(\n    retrieval=rag.Retrieval(\n        source=rag.VertexRagStore(\n            rag_resources=[\n                rag.RagResource(\n                    rag_corpus=\"projects/ai-trading-assistant-488403/locations/europe-west3/ragCorpora/2305843009213693952\"\n                )\n            ],\n            similarity_top_k=2,\n        ),\n    )\n)\n\n# 3. Use the 'Gemini 2.5 Flash' Model\n# In March 2026, 'gemini-2.5-flash' is the universal workhorse for RAG in Europe.\n# It bypasses the 404 errors seen with the older 1.5-pro strings.\nmodel = GenerativeModel(\"gemini-2.5-flash\")\n\nprint(\"\\n--- 🧠 Querying TBD Manuals for NYC Reversal (2026 Stable Path) ---\")\n\nquery = \"Based on 'FL-006_ NYC Reversal Day Trade.pdf', what are the mandatory Asia High/Low rules for entry? Explain the 'Liquidity Grab' requirement.\"\n\ntry:\n    response = model.generate_content(\n        query,\n        tools=[rag_tool]\n    )\n    \n    if response.candidates:\n        print(f\"\\nResponse:\\n{response.text}\")\n    else:\n        print(\"\\n⚠️ No response generated. Check if the PDFs are fully indexed in the Vertex Console.\")\n\nexcept Exception as e:\n    print(f\"\\n❌ Direct Audit Failed: {e}\")\n    print(\"\\nEngagement Lead Note: If 404 remains, we will switch to the 'global' location endpoint.\")"}]},{"codeLanguage":"python","filePath":"rag-21857/nyc_audit.py","includedReason":"RECENTLY_EDITED","segments":[{"content":"import vertexai\nfrom vertexai.preview import rag\nfrom vertexai.generative_models import GenerativeModel, Tool\n\n# 1. Initialize Frankfurt context\nvertexai.init(project=\"ai-trading-assistant-488403\", location=\"europe-west3\")\n\n# 2. Define the RAG Tool \nrag_tool = Tool.from_retrieval(\n    retrieval=rag.Retrieval(\n        source=rag.VertexRagStore(\n            rag_resources=[\n                rag.RagResource(\n                    rag_corpus=\"projects/521864748129/locations/europe-west3/ragCorpora/2305843009213693952\"\n                )\n            ],\n            similarity_top_k=5, \n        ),\n    )\n)\n\n# 3. Clean Model Call (Now that the SDK is patched)\nmodel = GenerativeModel(\"gemini-1.5-flash-002\")\n\nprint(\"\\n--- 🧠 Executing NYC Reversal Strategy Audit ---\")\n\nquery = \"\"\"\nAccording to 'FL-006_ NYC Reversal Day Trade.pdf', what are the mandatory \nrequirements for a 'UK Exhaustion' move before the NYC open? \nDetail the Asia High/Low interaction required for a valid setup.\n\"\"\"\n\ntry:\n    response = model.generate_content(\n        query,\n        tools=[rag_tool]\n    )\n    if response.candidates:\n        print(f\"\\nAudit Result:\\n{response.text}\")\n    else:\n        print(\"\\n⚠️ No response. The index may still be processing.\")\nexcept Exception as e:\n    print(f\"\\n❌ Audit Failed: {e}\")"}]},{"codeLanguage":"python","filePath":"rag-21857/refresh_corpus.py","includedReason":"RECENTLY_EDITED","segments":[{"content":"import vertexai\nfrom vertexai.preview import rag\n\n# Initialize Frankfurt context\nvertexai.init(project='ai-trading-assistant-488403', location='europe-west3')\n\n# Full Resource Path for the Frankfurt Corpus\nCORPUS_NAME = 'projects/521864748129/locations/europe-west3/ragCorpora/2305843009213693952'\nBUCKET_URI = 'gs://tbd-docs-frankfurt-ai-trading-assistant-488403'\n\nprint('--- 🔄 Triggering Frankfurt Corpus Sync ---')\n\ntry:\n    # In the March 2026 SDK, these are the confirmed parameter names\n    response = rag.import_files(\n        corpus_name=CORPUS_NAME,\n        paths=[BUCKET_URI],\n        chunk_size=1024,\n        chunk_overlap=200,\n    )\n    print('✅ Sync Request Submitted Successfully!')\nexcept Exception as e:\n    print(f'❌ Sync Failed: {e}')"}]},{"codeLanguage":"python","filePath":"rag-21857/agent.py","includedReason":"RECENTLY_OPENED","segments":[{"content":"import os\nimport vertexai\nfrom google.adk.agents.llm_agent import LlmAgent\nfrom google.adk.tools.retrieval.vertex_ai_rag_retrieval import VertexAiRagRetrieval\nfrom vertexai.preview import rag\n\n# Initialize with explicit project/location to stabilize the async stream\nvertexai.init(project=\"ai-trading-assistant-488403\", location=\"europe-west3\")\n\n# 1. Define the RAG Tool with a stricter 'Top K' \n# This prevents the 'Request contains an invalid argument' by slimming the payload\ntbd_manuals_tool = VertexAiRagRetrieval(\n    name=\"query_tbd_manuals\",\n    description=\"Search Steve's TBD manuals for NYC Reversal rules and Fibonacci levels.\",\n    rag_resources=[\n        rag.RagResource(\n            rag_corpus=\"projects/ai-trading-assistant-488403/locations/europe-west3/ragCorpora/2305843009213693952\"\n        )\n    ],\n    similarity_top_k=2, # Critical: Higher than 2 often triggers the 400 error in streaming\n)\n\n# 2. Define the Agent with the exact stable model and detailed TBD instructions\napp = LlmAgent(\n    name=\"tbd-trading-assistant\",\n    # Pinning to the exact stable version for regional reliability in Frankfurt\n    model=\"gemini-1.5-pro-002\", \n    tools=[tbd_manuals_tool],\n    instruction=\"\"\"You are Steve's expert TBD trading assistant. Use the 'query_tbd_manuals' tool for every audit.\n    When asked for an audit, use the tool to find exact rules from the manuals. \n    Focus specifically on:\n    - NYC Reversal (FL-006)\n    - Three-Level Expansion (FL-005)\n    - Fibonacci Rejection Zones\n    If the tool returns no data, tell Steve to check if the specific manual is indexed.\"\"\"\n)"}]}]},"metadata":{"duetProject":"cloudshell-gca","ideName":"Code OSS for Cloud Shell","ideType":"CLOUD_SHELL","ideVersion":"1.104.3-cde","platform":"LINUX_AMD64","pluginType":"CLOUD_CODE","pluginVersion":"2.72.0"},"project":"cloudshell-gca","requestId":"cloudcode-871671220-bf385f4c-5e9f-4dc5-91b7-b5e78e6b9733","userContext":{}}
