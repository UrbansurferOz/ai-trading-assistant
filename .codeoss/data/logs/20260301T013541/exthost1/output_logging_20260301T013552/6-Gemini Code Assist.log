I0301 03:39:33.207546    2002 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didSave: {"textDocument":{"uri":"file:///home/stevewwhite/rag-21857/rag/agent.py"},"text":"import os\nimport uuid\nfrom dotenv import load_dotenv\nfrom google.adk.agents import Agent\nfrom google.adk.tools.retrieval.vertex_ai_rag_retrieval import VertexAiRagRetrieval\nfrom vertexai.preview import rag\nfrom rag.tracing import instrument_adk_with_arize\nfrom .prompts import return_instructions_root\n\nload_dotenv()\n_ = instrument_adk_with_arize()\n\n# Move the tool definition outside, but ensure it's simple\nask_vertex_retrieval = VertexAiRagRetrieval(\n    name=\"retrieve_rag_documentation\",\n    description=\"Use this tool to retrieve Trade by Design methodology and Fibonacci rules.\",\n    rag_resources=[\n        rag.RagResource(\n            # This will be picked up from your .env or set via deployment env vars\n            rag_corpus=os.environ.get(\"RAG_CORPUS\")\n        )\n    ],\n    similarity_top_k=10,\n    vector_distance_threshold=0.6,\n)\n\n# DEFINE THE AGENT WITHOUT THE 'WITH' BLOCK\n# The 'using_session' is for local tracing, not for remote deployment.\nroot_agent = Agent(\n    model=\"gemini-2.5-flash\",\n    name=\"ask_rag_agent\",\n    instruction=return_instructions_root(),\n    tools=[\n        ask_vertex_retrieval,\n    ],\n)\n\nfrom google.adk.apps import App\napp = App(root_agent=root_agent, name=\"rag\")"}
