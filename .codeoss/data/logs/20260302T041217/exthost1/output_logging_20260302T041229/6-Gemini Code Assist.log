i.preview import rag\nfrom vertexai.generative_models import GenerativeModel, Tool\n\n# 1. Initialize Frankfurt context\n# We use the 'europe-west3' location but the 'global' endpoint is used under the hood in 2026\nvertexai.init(project=\"ai-trading-assistant-488403\", location=\"europe-west3\")\n\n# 2. Define the RAG Tool (March 2026 Flat Syntax)\nrag_tool = Tool.from_retrieval(\n    retrieval=rag.Retrieval(\n        source=rag.VertexRagStore(\n            rag_resources=[\n                rag.RagResource(\n                    rag_corpus=\"projects/ai-trading-assistant-488403/locations/europe-west3/ragCorpora/2305843009213693952\"\n                )\n            ],\n            similarity_top_k=2,\n        ),\n    )\n)\n\n# 3. Use the 'Gemini 2.5 Flash' Model\n# In March 2026, 'gemini-2.5-flash' is the universal workhorse for RAG in Europe.\n# It bypasses the 404 errors seen with the older 1.5-pro strings.\nmodel = GenerativeModel(\"gemini-2.5-flash\")\n\nprint(\"\\n--- 🧠 Querying TBD Manuals for NYC Reversal (2026 Stable Path) ---\")\n\nquery = \"Based on 'FL-006_ NYC Reversal Day Trade.pdf', what are the mandatory Asia High/Low rules for entry? Explain the 'Liquidity Grab' requirement.\"\n\ntry:\n    response = model.generate_content(\n        query,\n        tools=[rag_tool]\n    )\n    \n    if response.candidates:\n        print(f\"\\nResponse:\\n{response.text}\")\n    else:\n        print(\"\\n⚠️ No response generated. Check if the PDFs are fully indexed in the Vertex Console.\")\n\nexcept Exception as e:\n    print(f\"\\n❌ Direct Audit Failed: {e}\")\n    print(\"\\nEngagement Lead Note: If 404 remains, we will switch to the 'global' location endpoint.\")"}]},{"codeLanguage":"python","filePath":"rag-21857/refresh_corpus.py","includedReason":"COLOCATED","segments":[{"content":"import vertexai\nfrom vertexai.preview import rag\n\n# Initialize Frankfurt context\nvertexai.init(project='ai-trading-assistant-488403', location='europe-west3')\n\n# Full Resource Path for the Frankfurt Corpus\nCORPUS_NAME = 'projects/521864748129/locations/europe-west3/ragCorpora/2305843009213693952'\nBUCKET_URI = 'gs://tbd-docs-frankfurt-ai-trading-assistant-488403'\n\nprint('--- 🔄 Triggering Frankfurt Corpus Sync ---')\n\ntry:\n    # In the March 2026 SDK, these are the confirmed parameter names\n    response = rag.import_files(\n        corpus_name=CORPUS_NAME,\n        paths=[BUCKET_URI],\n        chunk_size=1024,\n        chunk_overlap=200,\n    )\n    print('✅ Sync Request Submitted Successfully!')\nexcept Exception as e:\n    print(f'❌ Sync Failed: {e}')"}]},{"codeLanguage":"python","filePath":"rag-21857/system_check.py","includedReason":"COLOCATED","segments":[{"content":"import vertexai\nfrom vertexai.generative_models import GenerativeModel\n\nPROJECT_ID = \"ai-trading-assistant-488403\"\n\nprint(\"\\n--- 🔍 Running Bare-Metal AI Diagnostics ---\")\n\n# Test 1: Frankfurt (europe-west3)\ntry:\n    vertexai.init(project=PROJECT_ID, location=\"europe-west3\")\n    # Using the most basic base model name\n    model = GenerativeModel(\"gemini-1.5-flash\")\n    print(\"Testing Frankfurt (europe-west3) connection...\")\n    res = model.generate_content(\"Reply with 'Frankfurt is online'.\")\n    print(f\"✅ Success: {res.text.strip()}\")\nexcept Exception as e:\n    print(f\"❌ Frankfurt Failed: {e}\")\n\n# Test 2: US Central (us-central1)\ntry:\n    vertexai.init(project=PROJECT_ID, location=\"us-central1\")\n    model = GenerativeModel(\"gemini-1.5-flash\")\n    print(\"\\nTesting US Central (us-central1) connection...\")\n    res = model.generate_content(\"Reply with 'US Central is online'.\")\n    print(f\"✅ Success: {res.text.strip()}\")\nexcept Exception as e:\n    print(f\"❌ US Central Failed: {e}\")"}]},{"codeLanguage":"python","filePath":"rag-21857/ping.py","includedReason":"COLOCATED","segments":[{"content":"from google import genai\n\n# Initialize the modern SDK client targeting Vertex AI\nclient = genai.Client(\n    vertexai=True, \n    project=\"ai-trading-assistant-488403\", \n    location=\"us-central1\"\n)\n\nprint(\"Sending diagnostic ping using the new GenAI SDK...\")\n\ntry:\n    response = client.models.generate_content(\n        model='gemini-1.5-flash',\n        contents='Hello Gemini, this is a diagnostic ping. Please reply with \"Connection successful.\"'\n    )\n    print(f\"\\n✅ SUCCESS! Response: {response.text.strip()}\")\nexcept Exception as e:\n    print(f\"\\n❌ FAILED. Raw error details:\\n{e}\")"}]},{"codeLanguage":"python","filePath":"rag-21857/nyc_audit.py","includedReason":"COLOCATED","segments":[{"content":"from google import genai\nfrom google.genai import types\n\n# 1. Initialize modern client targeting the 2026 stable endpoints\nclient = genai.Client(\n    vertexai=True,\n    project=\"ai-trading-assistant-488403\",\n    location=\"us-central1\"\n)\n\n# Your confirmed filename from the Frankfurt bucket\nFILENAME = \"FL-006_ NYC Reversal Day Trade (Post-UK Exhaustion Reversal) - Trade Travel Chill.pdf\"\n\nprint(f\"\\n--- 🧠 Executing NYC Reversal Strategy Audit (Gemini 2.0) ---\")\nprint(f\"Targeting: {FILENAME}\")\n\ntry:\n    print(\"Reading PDF data...\")\n    with open(FILENAME, \"rb\") as f:\n        pdf_bytes = f.read()\n\n    query = \"\"\"\n    Analyze the attached 'Trade by Design' manual. \n    1. List the mandatory requirements for a 'UK Exhaustion' move.\n    2. Explain the Asia High/Low interaction required. \n    3. Does the price need to break the Asia High/Low, or just interact with it?\n    \"\"\"\n\n    print(\"Requesting inference from Gemini 2.0 Flash...\")\n    # Using the current 2026 production model string\n    response = client.models.generate_content(\n        model='gemini-2.0-flash',\n        contents=[\n            types.Part.from_bytes(data=pdf_bytes, mime_type='application/pdf'),\n            query\n        ]\n    )\n\n    print(\"\\n\" + \"=\"*50)\n    print(\"STRATEGY AUDIT RESULT\")\n    print(\"=\"*50)\n    print(response.text)\n    print(\"=\"*50)\n\nexcept FileNotFoundError:\n    print(f\"\\n❌ Error: File '{FILENAME}' not found in current directory.\")\nexcept Exception as e:\n    print(f\"\\n❌ Audit Failed. Diagnostic Info:\\n{e}\")"}]}]},"metadata":{"duetProject":"cloudshell-gca","ideName":"Code OSS for Cloud Shell","ideType":"CLOUD_SHELL","ideVersion":"1.104.3-cde","platform":"LINUX_AMD64","pluginType":"CLOUD_CODE","pluginVersion":"2.72.0"},"project":"cloudshell-gca","requestId":"cloudcode-871671220-079f5878-fcd8-48f0-bba4-74d3d94155fb","userContext":{}}
